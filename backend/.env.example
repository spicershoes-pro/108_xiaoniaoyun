# ============================================================
# 霄鸟云 · 环境变量模板  (.env.example)
# 用途：新成员 clone 仓库后的配置参考
# 规则：此文件可提交到 Git，不含任何真实密钥
# 使用：cp .env.example .env 后按实际值填写
# ============================================================

# ── 应用基础 ─────────────────────────────────────────────────
APP_NAME=霄鸟云
APP_ENV=development
# APP_ENV 可选值：development | testing | staging | production
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_VERSION=1.0.0

# ── 数据库 ───────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
# 各环境数据库命名规范：
#   development → xiaoniao_dev
#   testing     → xiaoniao_test
#   staging     → xiaoniao_staging
#   production  → xiaoniao_prod
DB_NAME=xiaoniao_dev
DB_USER=root
DB_PASS=

# ── JWT ──────────────────────────────────────────────────────
# 生成命令：openssl rand -hex 32
JWT_SECRET=your-jwt-secret-min-32-chars-replace-this
JWT_EXPIRE_HOURS=168

# ── 短信服务 ─────────────────────────────────────────────────
# SMS_PROVIDER 可选值：mock | aliyun | tencent
SMS_PROVIDER=mock

# 阿里云短信（SMS_PROVIDER=aliyun 时填写）
# SMS_ACCESS_KEY=
# SMS_SECRET_KEY=
# SMS_SIGN_NAME=霄鸟云
# SMS_TEMPLATE_CODE=

# 腾讯云短信（SMS_PROVIDER=tencent 时填写）
# TENCENT_SECRET_ID=
# TENCENT_SECRET_KEY=
# TENCENT_SMS_APP_ID=
# TENCENT_SMS_TPL_ID=

# ── CORS 跨域 ────────────────────────────────────────────────
# 多个域名用逗号分隔；生产不允许使用 *
CORS_ORIGINS=*

# ── 文件上传 ─────────────────────────────────────────────────
# UPLOAD_DRIVER 可选值：local | oss
UPLOAD_MAX_MB=10
UPLOAD_DRIVER=local
UPLOAD_LOCAL_PATH=/tmp/xiaoniao/uploads/
UPLOAD_URL_PREFIX=http://localhost:8080/uploads/

# OSS 上传（UPLOAD_DRIVER=oss 时填写）
# OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
# OSS_BUCKET=xiaoniao-your-bucket
# OSS_ACCESS_KEY=
# OSS_SECRET_KEY=
# OSS_CDN_PREFIX=https://cdn.xiaoniao.com

# ── 缓存 ─────────────────────────────────────────────────────
# CACHE_DRIVER 可选值：none | redis
CACHE_DRIVER=none

# Redis（CACHE_DRIVER=redis 时填写）
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASS=
# REDIS_DB=0

# ── 日志 ─────────────────────────────────────────────────────
# LOG_LEVEL 可选值：debug | info | warning | error
# LOG_CHANNEL 可选值：stderr | file
LOG_LEVEL=debug
LOG_CHANNEL=stderr
# LOG_PATH=/var/log/xiaoniao/app.log

# ── 平台业务参数 ─────────────────────────────────────────────
PLATFORM_FEE_RATE=0.05
MIN_WITHDRAWAL=1000
INQUIRY_EXPIRE_DAYS=30
SAMPLE_MAX_QTY=5
