# ============================================================
# 霄鸟云 · 测试环境配置  (.env.testing)
# 适用：自动化测试 / CI Pipeline / 接口冒烟测试
# 规则：可提交到 Git（不含真实密钥）
# 注意：测试环境数据库每次 CI 前自动重建，严禁连接生产库
# ============================================================

# ── 应用基础 ─────────────────────────────────────────────────
APP_NAME=霄鸟云-TEST
APP_ENV=testing
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_VERSION=1.0.0

# ── 数据库（独立测试库，与开发库隔离） ──────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=xiaoniao_test
DB_USER=xiaoniao_test
DB_PASS=REPLACE_TEST_DB_PASS

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=xn-test-secret-ci-only-2026
JWT_EXPIRE_HOURS=24

# ── 短信（测试强制 mock） ────────────────────────────────────
SMS_PROVIDER=mock

# ── CORS（测试允许所有，方便自动化工具调用） ────────────────
CORS_ORIGINS=*

# ── 文件上传（测试用临时目录，CI后自动清理） ────────────────
UPLOAD_MAX_MB=5
UPLOAD_DRIVER=local
UPLOAD_LOCAL_PATH=/tmp/xiaoniao_test/uploads/
UPLOAD_URL_PREFIX=http://localhost:8080/uploads/

# ── 缓存（测试不启用） ───────────────────────────────────────
CACHE_DRIVER=none

# ── 日志 ─────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_CHANNEL=file
LOG_PATH=/tmp/xiaoniao_test/logs/app.log

# ── 平台业务参数（测试值与生产保持一致） ────────────────────
PLATFORM_FEE_RATE=0.05
MIN_WITHDRAWAL=1000
INQUIRY_EXPIRE_DAYS=30
SAMPLE_MAX_QTY=5

# ── 测试专属开关 ─────────────────────────────────────────────
# 测试环境允许万能验证码 123456
ALLOW_UNIVERSAL_CODE=true
# 测试结束后自动清理数据
AUTO_CLEAN_AFTER_TEST=true
