# 108_xiaoniaoyun · 开发状态（dev）设备与 Compose 对照
# 用法: set -a && source deploy/devices.dev.env && set +a

XNY_STATE=dev
XNY_IMAGE_TAG=dev

# ── 本地工作站（docker compose -f docker-compose.yml）──
XNY_DEVICE_LOCAL=local
XNY_LOCAL_COMPOSE_PROJECT=108_xiaoniaoyun_dev
XNY_LOCAL_COMPOSE_FILE=docker-compose.yml
XNY_LOCAL_MYSQL_PORT=3308
XNY_LOCAL_API_PORT=18080
XNY_LOCAL_VITE_PORTS=5173,5174,5175

# ── 库机 MM-V3-CORE-01 ──
XNY_DEVICE_DB=db
XNY_DB_HOSTNAME=MM-V3-CORE-01
XNY_DB_HOST=192.168.1.223
XNY_DB_SSH_USER=estar-03
XNY_DB_COMPOSE_PROJECT=108_xiaoniaoyun_db_dev
XNY_DB_COMPOSE_FILE=docker-compose.db-dev-remote.yml
XNY_DB_CONTAINER_MYSQL=108_xiaoniaoyun-mysql-dev
XNY_DB_MYSQL_PORT=3320
XNY_DB_VOLUME_DATA=xiaoniao-prod-db-data

# ── 应用机 MM-V2-PROD-01 ──
XNY_DEVICE_APP=app
XNY_APP_HOSTNAME=MM-V2-PROD-01
XNY_APP_HOST=192.168.1.87
XNY_APP_SSH_USER=ESTAR-02
XNY_APP_COMPOSE_PROJECT=108_xiaoniaoyun_app_dev
XNY_APP_COMPOSE_FILE=docker-compose.app-dev-remote.yml
XNY_APP_CONTAINER_REDIS=108_xiaoniaoyun-redis-dev
XNY_APP_CONTAINER_BACKEND=108_xiaoniaoyun-backend-dev
XNY_APP_CONTAINER_NGINX_API=108_xiaoniaoyun-nginx-api-dev
XNY_APP_CONTAINER_BUYER=108_xiaoniaoyun-buyer-dev
XNY_APP_CONTAINER_MERCHANT=108_xiaoniaoyun-merchant-dev
XNY_APP_CONTAINER_ADMIN=108_xiaoniaoyun-admin-dev
XNY_APP_API_PORT=8080
XNY_APP_VITE_PORTS=5173,5174,5175
XNY_APP_VOLUME_UPLOADS=xiaoniao-prod-uploads
XNY_APP_VOLUME_LOGS=xiaoniao-prod-logs
XNY_APP_MAC_DB_RELAY_PORT=13320

# ── 远程同步目录（三台机器相同路径）──
XNY_REMOTE_DIR=108_xiaoniaoyun_dev
XNY_REMOTE_ENV_FILE=deploy/.env.dev

# ── 运行时（内网联调默认为 staging + 万能验证码）──
XNY_APP_ENV=staging
XNY_DB_NAME=xiaoniao
XNY_ALLOW_UNIVERSAL_CODE=true
XNY_SEED_DATA=1
